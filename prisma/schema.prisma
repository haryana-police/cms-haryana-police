generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data.db"
}

// ── Auth / Profiles ──────────────────────────────────────────
model Profile {
  id          String   @id @default(uuid())
  username    String   @unique
  password    String
  role        String
  fullName    String
  badgeNumber String?
  rank        String?
  stationId   String?
  status      String   @default("active")
  createdAt   DateTime @default(now())

  @@map("profiles")
}

// ── Smart GD ─────────────────────────────────────────────────
model GdEntry {
  id                 String   @id @default(uuid())
  gdNumber           String   @unique
  gdDate             DateTime
  gdTime             String
  district           String   @default("Panchkula")
  policeStation      String
  beatArea           String?
  officerName        String   @default("System Officer") // DEFAULT so migration doesn't fail existing rows
  officerRank        String   @default("CONSTABLE")
  entryCategory      String   @default("INFORMATION")
  dutyType           String   @default("PATROL")
  priority           String   @default("NORMAL")
  personName         String?
  fatherName         String?
  mobileNumber       String?
  vehicleNumber      String?
  location           String
  complaintId        String?
  firId              String?
  summaryEn          String   @map("summary")
  summaryHi          String?  @map("hindi_summary")
  remarksEn          String?  @map("remarks")
  remarksHi          String?  @map("hindi_remarks")
  manualOverrideFlag Boolean  @default(false)
  overrideReason     String?
  attachmentUrl      String?
  intelligenceFlag   Boolean  @default(false)
  intelligenceReason String?
  confidenceScore    Float    @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("gd_entries")
}

// ── Preventive Policing ──────────────────────────────────────
model PreventiveHotspot {
  id           String   @id @default(uuid())
  area         String
  source       String
  totalSignals Int      @default(0)
  riskScore    Float    @default(0)
  type         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("preventive_hotspots")
}

model PreventivePattern {
  id          String   @id @default(uuid())
  patternType String
  description String
  area        String?
  linkedValue String?
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("preventive_patterns")
}

model PreventiveSuggestion {
  id        String   @id @default(uuid())
  area      String
  action    String
  priority  String   @default("MEDIUM")
  status    String   @default("PENDING")
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("preventive_suggestions")
}

model RepeatOffenderSignal {
  id             String   @id @default(uuid())
  personName     String?
  fatherName     String?
  mobileNumber   String?
  vehicleNumber  String?
  linkedArea     String?
  frequency      Int
  confidenceScore Float
  signalType     String
  summary        String
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("repeat_offender_signals")
}

model ShoAlert {
  id          String   @id @default(uuid())
  alertType   String
  severity    String
  title       String
  description String
  linkedArea  String?
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("sho_alerts")
}

model CrimePrediction {
  id             String   @id @default(uuid())
  district       String?
  policeStation  String?
  beatArea       String?
  areaName       String?
  predictedRisk  Float
  confidence     Float
  likelyTimeBand String?
  reason         String
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("crime_predictions")
}
